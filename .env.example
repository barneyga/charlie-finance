FRED_API_KEY=your_fred_api_key_here
DB_PATH=data/charlie.db

# Reddit API (optional, for sentiment analysis)
# Create app at https://www.reddit.com/prefs/apps/
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=charlie-finance/0.1

# StockTwits (optional — works without token at 200 req/hr)
# 1. Go to https://api.stocktwits.com/developers/login
# 2. Create an account or sign in
# 3. Register a new app at https://api.stocktwits.com/developers/apps/new
# 4. Copy your Access Token below (gives 400 req/hr instead of 200)
STOCKTWITS_ACCESS_TOKEN=

# Email alerts (optional, for critical/red alerts)
# Use your email provider's SMTP settings (e.g., Gmail: smtp.gmail.com, port 587)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
ALERT_EMAIL_TO=
